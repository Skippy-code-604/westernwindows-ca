rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Admin whitelist check
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email in ['shane@nsccr.ca'];
    }

    // Public read for website content (gallery, services, etc.)
    match /gallery/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /contractors/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /partners/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /services/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reviews/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Error logs (anyone can write for debugging, admin reads)
    match /error_logs/{document=**} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Settings (admin whitelist, etc.)
    match /settings/{document=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
